# Application
APP_NAME=PyWebFW
# Which modules this process serves: public | admin | scheduler (comma-separated).
# One codebase, deployable together or as separate FE/Admin/Scheduler servers.
APP_MODULES=public,admin,scheduler
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# Security (MUST override in production)
SECURITY_SECRET_KEY=change-me-to-a-long-random-string
SECURITY_TOKEN_TTL_SECONDS=3600
SECURITY_PASSWORD_ITERATIONS=310000

# Database
DB_DRIVER=sqlite             # sqlite | postgres (postgres: pip install "psycopg[binary]")
DB_PATH=data/app.db          # sqlite only
# DB_DSN=postgresql://user:password@dbhost:5432/pywebfw
DB_POOL_SIZE=5
DB_IDLE_TIMEOUT_SECONDS=300

# Cache
CACHE_BACKEND=memory         # memory | redis (redis: pip install redis)
CACHE_DEFAULT_TTL_SECONDS=120
# CACHE_REDIS_URL=redis://localhost:6379/0

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=5

# Rate limiting
RATELIMIT_MAX_REQUESTS=120
RATELIMIT_WINDOW_SECONDS=60
# Stricter window for POST /api/admin/auth/login (anti brute-force)
RATELIMIT_LOGIN_MAX_REQUESTS=5
RATELIMIT_LOGIN_WINDOW_SECONDS=300

# Domain + HTTPS (used by the Caddy proxy profile in docker-compose)
# DOMAIN=example.com
# ADMIN_DOMAIN=admin.example.com
